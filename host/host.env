# BuranBrew host configs

# RCP serial device. Use the stable /dev/serial/by-id path
# if02 = second VCOM (Spinel) on the nRF54L15 DK
RCP_DEV=/dev/serial/by-id/usb-SEGGER_J-Link_001057735468-if02

# chip-tool
CHIP_TOOL="$(command -v chip-tool || echo "$HOME/buranbrew/chip-tool_arm64")"
CHIP_STORAGE="$HOME/buranbrew/chip-storage"    # Persistent Matter controller storage

# NCS release tag, also matched by chip-tool binary
NCS_TAG=v3.3.0

# OTBR provisioning
INFRA_IF=eth0          # LAN interface for the border router
OTBR_REV=fbde28a       # Pinned ot-br-posix revision, bump alongside NCS_TAG

# Telemetry stack ports
# Change if native services already use them
REDIS_PORT=6379
POSTGRES_PORT=5433
GRAFANA_PORT=3000

# Matter node IDs (mirrored in models/config.yaml)
NODE_SENSOR=1
NODE_PLUG_HEAT=11
NODE_PLUG_COOL=12
